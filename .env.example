# =============================================================================
# PINNACLE HR - Environment Configuration Template
# =============================================================================
# SECURITY NOTICE:
# 1. Copy this file to .env.local for development
# 2. NEVER commit .env.local or any file containing actual secrets
# 3. Rotate all keys if you suspect they have been exposed
# 4. Use different keys for development, staging, and production
# =============================================================================

# -----------------------------------------------------------------------------
# CLERK AUTHENTICATION
# Get these from your Clerk Dashboard: https://dashboard.clerk.com
# -----------------------------------------------------------------------------

# Publishable Key (safe to expose client-side, prefixed with pk_)
# Used by the React frontend for Clerk initialization
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Secret Key (NEVER expose client-side, prefixed with sk_)
# Used only on the server-side for Clerk API calls
# CRITICAL: This key must remain secret - never commit or log it
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# JWT Issuer Domain (for Convex auth.config.js)
# Format: https://your-app-name.clerk.accounts.dev
# This tells Convex which Clerk instance to trust for JWT validation
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev

# -----------------------------------------------------------------------------
# CONVEX DATABASE
# Run 'npx convex dev' to get your Convex URL
# -----------------------------------------------------------------------------

# Convex Cloud URL for your deployment
# This URL is semi-public but should not be shared unnecessarily
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Convex deployment identifier (for npx convex dev)
# Format: dev:deployment-name or prod:deployment-name
CONVEX_DEPLOYMENT=dev:your-deployment-name

# -----------------------------------------------------------------------------
# OPTIONAL: ADDITIONAL SECURITY SETTINGS
# -----------------------------------------------------------------------------

# Rate limiting configuration (requests per window)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100

# Session timeout in milliseconds (default: 30 minutes)
# SESSION_TIMEOUT_MS=1800000

# -----------------------------------------------------------------------------
# PRODUCTION CHECKLIST
# -----------------------------------------------------------------------------
# Before deploying to production, ensure:
# [ ] All pk_test_ keys are replaced with pk_live_ keys
# [ ] All sk_test_ keys are replaced with sk_live_ keys
# [ ] JWT issuer domain points to production Clerk instance
# [ ] Convex deployment is set to production
# [ ] CORS origins are properly configured
# [ ] Rate limiting is enabled
# [ ] All test data is removed from production database
# =============================================================================
